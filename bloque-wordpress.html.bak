<!-- ══ CHATBOT uChat (widget flotante) ══════════════════ -->
<script async defer src="https://www.uchat.com.au/js/widget/3hj49k6plscpvkpr/float.js"></script>

<script>
(function(){
  "use strict";
  /* Smooth scroll */
  document.addEventListener("click",function(e){
    var a=e.target.closest('a[href^="#av-"]');
    if(!a)return;
    var el=document.querySelector(a.getAttribute("href"));
    if(!el)return;
    e.preventDefault();
    el.scrollIntoView({behavior:"smooth",block:"start"});
  });
  /* Reveal */
  var items=document.querySelectorAll(".av-reveal");
  if(items.length){
    var io=new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if(!e.isIntersecting)return;
        var el=e.target,d=parseInt(el.dataset.avDelay,10)||0;
        setTimeout(function(){el.classList.add("is-visible");},d);
        io.unobserve(el);
      });
    },{threshold:0.04,rootMargin:"0px 0px -3% 0px"});
    items.forEach(function(el){io.observe(el);});
    setTimeout(function(){
      document.querySelectorAll(".av-reveal:not(.is-visible)").forEach(function(el){
        if(el.getBoundingClientRect().top<window.innerHeight)el.classList.add("is-visible");
      });
    },6000);
  }
  /* Count-up */
  var counts=document.querySelectorAll("[data-av-count]");
  if(counts.length){
    var cio=new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if(!e.isIntersecting)return;
        var el=e.target,target=parseInt(el.dataset.avCount,10),start=performance.now(),dur=1800;
        cio.unobserve(el);
        (function tick(now){
          var p=Math.min((now-start)/dur,1),eased=1-Math.pow(1-p,3);
          el.textContent=Math.round(eased*target).toLocaleString("es");
          if(p<1)requestAnimationFrame(tick);
        })(start);
      });
    },{threshold:0.05});
    counts.forEach(function(el){cio.observe(el);});
  }
  /* Carousel auto-rotate */
  var carousels=document.querySelectorAll(".av-carousel");
  carousels.forEach(function(carousel){
    var imgs=carousel.querySelectorAll(".av-carousel-img");
    if(imgs.length<2)return;
    var idx=0;
    imgs[idx].classList.add("is-active");
    setInterval(function(){
      imgs[idx].classList.remove("is-active");
      idx=(idx+1)%imgs.length;
      imgs[idx].classList.add("is-active");
    },5000);
  });
})();
</script>
